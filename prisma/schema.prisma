generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  REGION_ADMIN
  PARKING_ADMIN
  OPERATOR
}

enum CameraType {
  ENTRY
  EXIT
}

enum CameraStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

enum SessionStatus {
  ACTIVE     // Mashina ichkarida
  CLOSED     // Normal chiqib ketdi
  CANCELLED  // Bekor qilindi
  LOST       // Chiqish bo'lmadi, admin yopdi
  MANUAL     // Operator tomonidan yaratildi
}

enum PaymentStatus {
  PAID
  UNPAID
  PENDING
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  FREE       // Whitelist / abonent
}

enum EntryMethod {
  AUTO       // Kamera orqali
  MANUAL     // Operator qo'lda kiritdi
}

enum SessionEventType {
  ENTRY_CAPTURED
  EXIT_CAPTURED
  MANUAL_ENTRY
  MANUAL_EXIT
  PAYMENT_CONFIRMED
  SESSION_CLOSED
  SESSION_CANCELLED
  PLATE_CORRECTED
  PRICE_RECALCULATED
}

enum VehicleListType {
  WHITELIST  // VIP, abonent — bepul yoki chegirmali
  BLACKLIST  // Taqiqlangan
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(uuid())
  fullName     String
  username     String        @unique
  phone        String?
  passwordHash String
  role         Role          @default(OPERATOR)

  regionId     String?
  region       Region?       @relation(fields: [regionId], references: [id])

  parkingId    String?
  parking      Parking?      @relation(fields: [parkingId], references: [id])

  isActive     Boolean       @default(true)

  auditLogs    AuditLog[]
  telegramChat TelegramChat?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("users")
}

model Region {
  id       String    @id @default(uuid())
  name     String
  code     String?   @unique  // "TSH", "AND", "NAM"
  isActive Boolean   @default(true)

  users    User[]
  parkings Parking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("regions")
}

model Parking {
  id           String           @id @default(uuid())
  name         String
  address      String?
  capacity     Int?             // Jami joy soni
  isActive     Boolean          @default(true)

  regionId     String
  region       Region           @relation(fields: [regionId], references: [id])

  tariffPlanId String?
  tariffPlan   TariffPlan?      @relation(fields: [tariffPlanId], references: [id])

  cameras      Camera[]
  sessions     VehicleSession[]
  users        User[]

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("parkings")
}

model Camera {
  id           String        @id @default(uuid())
  name         String
  type         CameraType
  vendor       String        @default("HIKVISION")
  ipAddress    String?
  serialNumber String?
  webhookKey   String?       // Webhook autentifikatsiya kaliti
  status       CameraStatus  @default(UNKNOWN)
  lastSeenAt   DateTime?     // Oxirgi faollik vaqti
  isActive     Boolean       @default(true)

  parkingId    String
  parking      Parking       @relation(fields: [parkingId], references: [id])

  entrySessions VehicleSession[] @relation("EntryCamera")
  exitSessions  VehicleSession[] @relation("ExitCamera")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("cameras")
}

// ─── Tarif ───────────────────────────────────────────────────────────────────

model TariffPlan {
  id          String       @id @default(uuid())
  name        String
  description String?
  isActive    Boolean      @default(true)

  rules       TariffRule[]
  parkings    Parking[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tariff_plans")
}

model TariffRule {
  id           String     @id @default(uuid())
  tariffPlanId String
  tariffPlan   TariffPlan @relation(fields: [tariffPlanId], references: [id], onDelete: Cascade)

  fromMinutes  Int        // 0
  toMinutes    Int?       // null = ∞
  price        Int        // so'mda
  label        String?    // "0-3 soat" — UI uchun

  sortOrder    Int        @default(0)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("tariff_rules")
}

// ─── Vehicle Session ─────────────────────────────────────────────────────────

model VehicleSession {
  id              String         @id @default(uuid())
  plateNumber     String
  country         String         @default("UZ")
  confidence      Float?         // Kamera tanish ishonchliligi 0–100

  entryTime       DateTime       @default(now())
  exitTime        DateTime?
  durationMinutes Int?

  status          SessionStatus  @default(ACTIVE)
  entryMethod     EntryMethod    @default(AUTO)
  exitMethod      EntryMethod?

  totalAmount     Int?
  paymentStatus   PaymentStatus  @default(UNPAID)

  entryImageUrl   String?        // Kirish snapshot URL
  exitImageUrl    String?        // Chiqish snapshot URL
  note            String?        // Operator izohi

  regionId        String?
  parkingId       String
  parking         Parking        @relation(fields: [parkingId], references: [id])

  entryCameraId   String?
  entryCamera     Camera?        @relation("EntryCamera", fields: [entryCameraId], references: [id])
  exitCameraId    String?
  exitCamera      Camera?        @relation("ExitCamera", fields: [exitCameraId], references: [id])

  tariffPlanId    String?        // Qaysi tarif ishlatildi (snapshot)

  payment         Payment?
  events          SessionEvent[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([plateNumber])
  @@index([parkingId, status])
  @@index([entryTime])
  @@map("vehicle_sessions")
}

model Payment {
  id        String         @id @default(uuid())
  sessionId String         @unique
  session   VehicleSession @relation(fields: [sessionId], references: [id])

  amount    Int
  method    PaymentMethod  @default(CASH)
  status    PaymentStatus  @default(PAID)
  paidAt    DateTime       @default(now())
  paidBy    String?        // Operator ID yoki "AUTO"
  note      String?

  @@map("payments")
}

// ─── Session Events (Audit Trail) ────────────────────────────────────────────

model SessionEvent {
  id        String           @id @default(uuid())
  sessionId String
  session   VehicleSession   @relation(fields: [sessionId], references: [id])

  type      SessionEventType
  payload   Json?            // Raw event yoki o'zgarish ma'lumoti
  createdBy String?          // Operator ID yoki "SYSTEM"

  createdAt DateTime         @default(now())

  @@map("session_events")
}

// ─── Whitelist / Blacklist ───────────────────────────────────────────────────

model VehicleList {
  id          String          @id @default(uuid())
  plateNumber String
  country     String          @default("UZ")
  type        VehicleListType

  parkingId   String?         // null = barcha parkinglar
  regionId    String?         // null = barcha regionlar

  discount    Int?            // % chegirma (Whitelist uchun)
  note        String?
  isActive    Boolean         @default(true)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([plateNumber, type, parkingId])
  @@map("vehicle_list")
}

// ─── Telegram Bot ─────────────────────────────────────────────────────────────

model TelegramChat {
  id       String  @id @default(uuid())
  chatId   String  @unique
  username String?
  isActive Boolean @default(true)

  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("telegram_chats")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])

  action    AuditAction
  entity    String      // "Parking", "TariffPlan", "VehicleSession"
  entityId  String?
  oldValue  Json?
  newValue  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}
